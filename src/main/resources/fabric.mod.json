{
  "schemaVersion": 1,
  "id": "capey",
  "version": "${version}",
  "name": "Capey",
  "description": "Have a custom cape which others who use this mod can see too",
  "authors": ["JGJ52"],
  "contact": {},
  "license": "GPL-3.0",
  "icon": "assets/capey/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "hu.jgj52.capey.client.CapeyClient"
    ],
    "main": [
      "hu.jgj52.capey.Capey"
    ],
    "modmenu": [
      "hu.jgj52.capey.config.ModMenu"
    ]
  },
  "mixins": [
    "${mixins_file}"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ">=${minecraft_version} <=${minecraft_higher_version}",
    "screenapi": "${screenapi_version}"
  },
  "custom": {
    "modmenu": {
      "links": {
        "modmenu.modrinth": "https://modrinth.com/mod/capey",
        "modmenu.discord": "https://discord.gg/5pjP2DxQK8"
      },
      "update_checker": true
    }
  }
}
